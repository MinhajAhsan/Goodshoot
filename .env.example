# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# ---- Supabase (client-safe) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_or_anon_key

# ---- Supabase (server-only secret) ----
SUPABASE_SERVICE_ROLE_KEY=service_role_key

# ---- Postgres for Prisma (Project Settings -> Database -> Connection string -> ORM/Prisma) ----
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ---- Admin ----
INNOVATOR_EMAIL=you@example.com

# ---- Email (Resend) — Phase 4 ----
RESEND_API_KEY=resend_api_key

# ---- Calendly ----
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-handle/consultation
CALENDLY_API_TOKEN=calendly_personal_access_token

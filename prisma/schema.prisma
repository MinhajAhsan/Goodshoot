// GoodShoot — Prisma schema (v1)
// Postgres on Supabase. Classic prisma-client-js generator -> import from "@prisma/client".

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (pgbouncer, 6543) — app runtime
  directUrl = env("DIRECT_URL") // direct (5432) — migrations
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

enum AuthProvider {
  email
  google
}

enum BookingStatus {
  draft
  quoted
  consultation_scheduled
  consultation_completed
  paid_50
  assigned
  in_progress
  delivered
  completed
  cancelled
  abandoned
}

enum PaymentMethod {
  bank_transfer
  jazzcash
  cash
  other
}

enum PaymentStatus {
  pending
  success
  failed
  refunded
}

enum AbandonmentReason {
  saw_quote
  no_follow_up
  budget_concern
  other
}

enum RecontactStatus {
  not_contacted
  contacted_1
  contacted_2
  converted
  do_not_contact
}

enum DeliverableFileType {
  video
  photo
  document
}

enum AuditEntityType {
  booking
  payment
  specialist_assignment
}

enum AuditAction {
  created
  updated
  status_changed
  assigned
  deleted
}

enum ActorType {
  client
  specialist
  innovator
}

// ----------------------------------------------------------------------------
// Models
// ----------------------------------------------------------------------------

model User {
  id                     String       @id @default(uuid()) @db.Uuid
  email                  String       @unique
  phone                  String?
  fullName               String?
  profilePictureUrl      String?
  cityId                 String?      @db.Uuid
  authProvider           AuthProvider @default(email)
  passwordHash           String? // auth handled by Supabase; kept for schema parity
  isSpecialist           Boolean      @default(false)
  specialistBio          String?
  specialistPortfolioUrl String?
  specialistVerified     Boolean      @default(false)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  deletedAt              DateTime?

  city                   City?                   @relation(fields: [cityId], references: [id])
  specialistProfile      Specialist?
  questionnaireResponses QuestionnaireResponse[]
  quotes                 Quote[]
  bookings               Booking[]

  @@index([cityId])
}

model City {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  countryCode String   @default("PK")
  timezone    String   @default("Asia/Karachi")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users    User[]
  bookings Booking[]
}

model Specialist {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String?   @unique @db.Uuid
  displayName         String
  bio                 String?
  profilePictureUrl   String?
  portfolioUrl        String?
  cities              String[]  @db.Uuid // UUID array of City ids
  experienceYears     Int?
  specializations     String[]
  ratePerHour         Decimal?  @db.Decimal(12, 2)
  isActive            Boolean   @default(true)
  isVerified          Boolean   @default(false)
  primaryContactName  String?
  primaryContactPhone String?
  primaryContactEmail String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  user         User?         @relation(fields: [userId], references: [id])
  deliverables Deliverable[]
}

model QuestionnaireTemplate {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  version      Int      @default(1)
  isActive     Boolean  @default(true)
  questionFlow Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  responses QuestionnaireResponse[]
}

model QuestionnaireResponse {
  id         String   @id @default(uuid()) @db.Uuid
  clientId   String?  @db.Uuid
  templateId String   @db.Uuid
  responses  Json
  createdAt  DateTime @default(now())

  client   User?                 @relation(fields: [clientId], references: [id])
  template QuestionnaireTemplate @relation(fields: [templateId], references: [id])
  quotes   Quote[]
  leads    Lead[]

  @@index([clientId])
}

model Quote {
  id                      String   @id @default(uuid()) @db.Uuid
  clientId                String?  @db.Uuid
  questionnaireResponseId String   @db.Uuid
  baseAmount              Decimal  @db.Decimal(12, 2)
  additionalCharges       Json?
  totalAmount             Decimal  @db.Decimal(12, 2)
  currencyCode            String   @default("PKR")
  exchangeRate            Decimal  @default(1.0) @db.Decimal(12, 6)
  isActive                Boolean  @default(true)
  expiresAt               DateTime
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  client                User?                 @relation(fields: [clientId], references: [id])
  questionnaireResponse QuestionnaireResponse @relation(fields: [questionnaireResponseId], references: [id])
  bookings              Booking[]
  leads                 Lead[]

  @@index([clientId])
}

model Booking {
  id                    String        @id @default(uuid()) @db.Uuid
  clientId              String        @db.Uuid
  quoteId               String        @db.Uuid
  specialists           String[]      @db.Uuid // assigned specialist ids (denormalized per spec)
  eventDate             DateTime?     @db.Date
  eventTime             String?
  eventLocation         String?
  cityId                String?       @db.Uuid
  pocName               String?
  pocPhone              String?
  pocEmail              String?
  status                BookingStatus @default(draft)
  totalAmount           Decimal       @db.Decimal(12, 2)
  firstPaymentAmount    Decimal?      @db.Decimal(12, 2)
  secondPaymentAmount   Decimal?      @db.Decimal(12, 2)
  currencyCode          String        @default("PKR")
  consultationSlotTime  DateTime?
  consultationScheduled Boolean       @default(false)
  consultationNotes     String?
  clientNotes           String?
  innovatorNotes        String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  completedAt           DateTime?
  deletedAt             DateTime?

  client       User          @relation(fields: [clientId], references: [id])
  quote        Quote         @relation(fields: [quoteId], references: [id])
  city         City?         @relation(fields: [cityId], references: [id])
  payments     Payment[]
  deliverables Deliverable[]
  auditLogs    AuditLog[]

  @@index([clientId])
  @@index([status])
}

model Payment {
  id                   String        @id @default(uuid()) @db.Uuid
  bookingId            String        @db.Uuid
  amount               Decimal       @db.Decimal(12, 2)
  currencyCode         String        @default("PKR")
  paymentOrder         Int // 1 (first 50%) or 2 (second 50%)
  paymentMethod        PaymentMethod
  gateway              String?
  gatewayTransactionId String?
  gatewayResponse      Json?
  status               PaymentStatus @default(pending)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  completedAt          DateTime?

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}

model Lead {
  id                      String             @id @default(uuid()) @db.Uuid
  email                   String
  phone                   String?
  fullName                String?
  questionnaireResponseId String?            @db.Uuid
  quoteId                 String?            @db.Uuid
  abandonmentReason       AbandonmentReason?
  recontactStatus         RecontactStatus    @default(not_contacted)
  lastRecontactAt         DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  questionnaireResponse QuestionnaireResponse? @relation(fields: [questionnaireResponseId], references: [id])
  quote                 Quote?                 @relation(fields: [quoteId], references: [id])

  @@index([recontactStatus])
}

model Deliverable {
  id                     String              @id @default(uuid()) @db.Uuid
  bookingId              String              @db.Uuid
  fileName               String
  fileUrl                String
  fileType               DeliverableFileType
  fileSizeMb             Decimal?            @db.Decimal(12, 2)
  uploadedBySpecialistId String?             @db.Uuid
  uploadedByInnovator    Boolean             @default(false)
  createdAt              DateTime            @default(now())
  deletedAt              DateTime?

  booking              Booking     @relation(fields: [bookingId], references: [id])
  uploadedBySpecialist Specialist? @relation(fields: [uploadedBySpecialistId], references: [id])

  @@index([bookingId])
}

model AuditLog {
  id         String          @id @default(uuid()) @db.Uuid
  bookingId  String?         @db.Uuid
  entityType AuditEntityType
  action     AuditAction
  actorType  ActorType
  actorId    String?         @db.Uuid
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  createdAt  DateTime        @default(now())

  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}

model AdminSettings {
  id                     String   @id @default(uuid()) @db.Uuid
  baseQuoteAmount        Decimal  @db.Decimal(12, 2)
  currency               String   @default("PKR")
  activeCities           String[] @db.Uuid
  paymentGatewayPrimary  String?
  paymentGatewayFallback String?
  firstPaymentPercentage Int      @default(50)
  quoteValidityHours     Int      @default(24)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}
